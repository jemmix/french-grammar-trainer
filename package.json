{
  "name": "french-grammar-trainer",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "predev": "node --env-file-if-exists=.env --env-file-if-exists=.env.development --env-file-if-exists=.env.development.local scripts/fetch-allowlist.mjs",
    "dev": "next dev --turbo",
    "prebuild": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/fetch-allowlist.mjs",
    "build": "next build",
    "start": "next start",
    "preview": "next build && next start",
    "typecheck": "tsc --noEmit",
    "validate-content": "npx tsx scripts/validate-content.ts",
    "validate-txt": "npx tsx scripts/validate-txt.ts",
    "convert-txt": "npx tsx scripts/convert-txt.ts",
    "split-txt": "npx tsx scripts/split-txt.ts",
    "merge-txt": "npx tsx scripts/merge-txt.ts",
    "generate-section": "npx tsx scripts/generate-section.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/core": "^0.41.0",
    "@aws-sdk/client-s3": "^3.1001.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tailwindcss/postcss": "^4.2.0",
    "better-sqlite3": "^12.6.2",
    "hash-wasm": "^4.12.0",
    "next": "^15.2.3",
    "next-auth": "^5.0.0-beta.30",
    "postcss": "^8.5.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.8.2"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "npm@10.9.0"
}
