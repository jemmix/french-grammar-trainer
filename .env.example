# Copy this file to ".env.local" and fill in the values.
# Never commit secrets to version control.

# ─── Existing ────────────────────────────────────────────────────────

# HMAC secret for signing session cookies (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=""

# Set to "1" in dev to allow only mangleUserId("0") as the sole permitted user
# ALLOW_LIST_DEV_MODE="1"

# ─── WP1: Google OAuth (next-auth) ──────────────────────────────────

# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (type: Web application)
# 3. Add authorized redirect URIs:
#      - http://localhost:3000/api/auth/callback/google   (local dev)
#      - https://<your-vercel-domain>/api/auth/callback/google   (production)
# 4. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Random secret for next-auth JWT signing
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Production only — your canonical app URL (Vercel sets this automatically on deploy)
# Not needed locally (next-auth defaults to http://localhost:3000)
# NEXTAUTH_URL="https://your-app.vercel.app"

# Random secret for Argon2id user-ID mangling salt
# Generate: openssl rand -hex 32
HMAC_KEY=""

# ─── WP2: Allow-list (GitHub Gist) ──────────────────────────────────

# 1. Create a GitHub Gist at https://gist.github.com (can be secret/unlisted)
# 2. Add a file named "allowlist.txt" — one mangled user ID per line
# 3. Click "Raw" on that file and copy the URL
#    Format: https://gist.githubusercontent.com/<user>/<gist-id>/raw/allowlist.txt
ALLOW_LIST_GIST_URL=""

# ─── WP3: S3-Compatible Object Storage ──────────────────────────────

# Any S3-compatible provider works (Cloudflare R2, AWS S3, MinIO, etc.)
#
# Example: Cloudflare R2 (free tier — 10 GB storage, 10M reads/mo)
# 1. Sign up at https://dash.cloudflare.com
# 2. Go to R2 → Create bucket (e.g. "fgt-users")
# 3. Go to R2 → Manage R2 API Tokens → Create API token
#    - Permissions: Object Read & Write
#    - Specify the bucket you created
# 4. Copy the token's Access Key ID and Secret Access Key below
# 5. Endpoint format: https://<account-id>.r2.cloudflarestorage.com
#
# Local dev with MinIO (Docker):
#   docker run -d --name fgt-minio \
#     -p 9000:9000 -p 9001:9001 \
#     -e MINIO_ROOT_USER=minioadmin \
#     -e MINIO_ROOT_PASSWORD=minioadmin \
#     -v ./minio-data:/data \
#     minio/minio server /data --console-address ":9001"
#   Then create bucket "fgt-users" at http://localhost:9001
#
#   For local dev, use:
#     S3_ENDPOINT=http://localhost:9000
#     S3_ACCESS_KEY_ID=minioadmin
#     S3_SECRET_ACCESS_KEY=minioadmin

S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="fgt-users"

# ─── Language ────────────────────────────────────────────────────────

# Build-time language selection: "fr" (default) or "en"
# NEXT_PUBLIC_LANG="fr"
